# Supabase PostgreSQL (use "Connection string" from Project Settings > Database)
# For direct connection: Session mode; for pooler: Transaction mode, set prepare: false in code.
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Server
PORT=3000
NODE_ENV=development

# Optional: Gemini model fallback when YAML prompt config does not specify model (default: gemini-2.0-flash)
# Override per-prompt in config/prompts/*.yaml via the model field.
# GEMINI_MODEL=gemini-2.0-flash

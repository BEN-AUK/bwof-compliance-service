# Supabase PostgreSQL (use "Connection string" from Project Settings > Database)
# For direct connection: Session mode; for pooler: Transaction mode, set prepare: false in code.
DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase API (Auth, Storage, RLS). Required for InfraService (Storage, signed URLs).
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=[YOUR-SUPABASE-ANON-KEY]
# Service role key (Project Settings > API): required for Storage admin and signed URLs. Keep secret.
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SUPABASE-SERVICE-ROLE-KEY]

# Google Gemini API (InfraService, AI parsing). Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=[YOUR-GEMINI-API-KEY]

# Optional: Storage bucket name (default: documents). Override if using a different bucket.
# STORAGE_BUCKET=documents

# Optional: Path to prompts YAML (default: config/prompts.yaml, relative to process.cwd())
# PROMPTS_CONFIG_FILE=config/prompts.yaml

# Optional: AI / file-upload defaults (FileUploadAiService)
# AI_REQUEST_TIMEOUT_MS=30000
# SIGNED_URL_EXPIRY_SECONDS=300
# GEMINI_MODEL=gemini-2.0-flash

# Server
PORT=3000
NODE_ENV=development
